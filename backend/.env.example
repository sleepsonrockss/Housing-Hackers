# TenantTales Backend Configuration

# Gemini API Key - Get from https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Server Configuration
PORT=5001
NODE_ENV=development

# Muse / LSL stress calibration (Play customized)
# 1) Run: muselsl stream  (separate terminal)
# 2) pip install -r requirements-eeg.txt
# 3) Enable one of:
USE_LSL_EEG=1
# EEG_CALIBRATE_SCRIPT=./scripts/eeg_calibrate_lsl.py
# EEG_CALIBRATE_PYTHON=python3
# EEG_LSL_DURATION_SEC=10

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Video Generation Settings
VIDEO_TIMEOUT=30000
GENERATION_CACHE=true
